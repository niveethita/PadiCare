SESSION_CLEANUP_INTERVAL=3600000

# Optional: Session max age in milliseconds (default: 24 hours)
SESSION_MAX_AGE=86400000

GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT_ID=
VERTEX_DATASTORE_ID=
VERTEX_ENGINE_ID=